{
  "name": "fairwhistle",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Match-integrity surveillance agent: watches odds microstructure for patterns consistent with fixing or informed money, and publishes timestamped, attested alerts.",
  "scripts": {
    "test:cycle": "tsx scripts/test-cycle.ts",
