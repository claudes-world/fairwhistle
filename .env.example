# Agent Ed25519 signing key, base64 PKCS8. Generate with: pnpm gen:key
# Without it the agent generates an ephemeral per-instance key (labeled in-UI).
FAIRWHISTLE_SIGNING_KEY=

# Optional custom devnet RPC for scripts/anchor-devnet.ts
SOLANA_DEVNET_RPC=

# Optional: enables /api/live — real TxLINE mainnet ingestion (free tier).
# Without it the live panel stays hidden; the detection demo is unaffected.
TXLINE_API_TOKEN=
TXLINE_FIXTURE_ID=18257739
TXLINE_FIXTURE_LABEL="FIFA World Cup Final — Spain v Argentina"
